#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use App\Command\ProcessCommand;
use App\Service\DateParser;
use App\Service\MessageClassifier;
use App\Service\MessageProcessor;
use App\Service\MessageValidator;
use Symfony\Component\Console\Application;

$application = new Application('Message Processor', '1.0.0');

$validator = new MessageValidator();
$classifier = new MessageClassifier();
$dateParser = new DateParser();
$processor = new MessageProcessor($validator, $classifier, $dateParser);

$application->add(new ProcessCommand($processor));

$application->run();
